# ===== LLM Provider =====
# 사용 가능값 예시: groq, openai
TRPG_API_PROVIDER="groq"

# ===== GroqCloud =====
# https://console.groq.com/ 에서 발급한 API Key
GROQ_API_KEY="gsk_your_real_key_here"

# 모델명 예시(상황에 맞게 변경)
# 최신 모델명은 Groq 콘솔/문서에서 확인하세요.
GROQ_MODEL="llama-3.3-70b-versatile"

# ===== Optional OpenAI Fallback =====
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# ===== TRPG Runtime Options (optional) =====
TRPG_EPISODES="1000"
TRPG_LEARNING_RATE="0.1"
TRPG_EPSILON_START="0.30"
TRPG_EPSILON_END="0.05"
TRPG_USE_OPENAI_FOR_TRAINING="false"
TRPG_USE_OPENAI_FOR_FINAL_TEST="false"
